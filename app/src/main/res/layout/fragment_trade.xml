<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:divider="?android:attr/listDivider"
        android:showDividers="middle">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. 设定初始交易参数"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="搜索"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="4dp" />

                <AutoCompleteTextView
                    android:id="@+id/search_edit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="输入代码或名称搜索..."
                    android:maxLines="1"
                    android:inputType="textFilter"
                    android:textColor="@android:color/black"
                    android:textColorHint="@android:color/darker_gray" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:gravity="end">

                    <CheckBox
                        android:id="@+id/etf_filter_check"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="仅显示ETF"
                        android:textSize="12sp"
                        android:textColor="#666666" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="股票代码"
                            android:textSize="13sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/stock_code"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="代码"
                            android:textColor="@android:color/black" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="股票名称"
                            android:textSize="13sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/stock_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="股票名称"
                            android:textColor="@android:color/black"
                            android:textColorHint="@android:color/darker_gray" />
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="买入价（元）"
                            android:textSize="13sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/buy_price"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="元"
                            android:inputType="numberDecimal"
                            android:textColor="@android:color/black" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="买入日期"
                            android:textSize="13sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/buy_date"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="yyyy-MM-dd"
                            android:gravity="center"
                            android:minEms="8"
                            android:focusable="false"
                            android:cursorVisible="false"
                            android:inputType="none"
                            android:textColor="@android:color/black" />
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="止损（%）"
                            android:textSize="13sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/stop_loss_percent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="%"
                            android:text="3"
                            android:inputType="numberDecimal"
                            android:textColor="@android:color/black" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="止盈（%）"
                            android:textSize="13sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/target_profit_percent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="%"
                            android:text="15"
                            android:inputType="numberDecimal"
                            android:textColor="@android:color/black" />
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="回撤（%）"
                            android:textSize="13sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/trailing_percent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="%"
                            android:text="0"
                            android:inputType="numberDecimal"
                            android:enabled="false"
                            android:textColor="@android:color/black" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

                <CheckBox
                    android:id="@+id/use_graded"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="启用分级移动止盈"
                    android:checked="false"
                    android:layout_marginTop="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="当前股价"
                            android:textSize="13sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/current_price"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="手动输入股价或点联网更新"
                            android:inputType="numberDecimal"
                            android:textColor="@android:color/black" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/update_price_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="联网更新"
                        android:textColor="@android:color/white"
                        android:layout_gravity="bottom" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <Button
                        android:id="@+id/confirm_price_btn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="更新仪表盘"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#FF8F00"
                        android:layout_marginEnd="4dp" />

                    <Button
                        android:id="@+id/clear_trade_btn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="结束/重置"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#757575"
                        android:layout_marginStart="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <Button
                        android:id="@+id/save_preset_btn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="保存参数"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#4CAF50"
                        android:layout_marginEnd="4dp" />

                    <Button
                        android:id="@+id/ai_analysis_btn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="AI分析"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#1565C0"
                        android:layout_marginStart="4dp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/dashboard_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardElevation="2dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2. 监控仪表盘"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp" />

                <TextView android:id="@+id/dashboard_highest" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="15sp" android:background="#FFF3E0" android:padding="6dp" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/dashboard_defense" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="15sp" android:background="#E3F2FD" android:padding="6dp" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/dashboard_hard_stop" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="15sp" android:background="#FFEBEE" android:padding="6dp" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/dashboard_profit" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="15sp" android:background="#E8F5E9" android:padding="6dp" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/dashboard_drawdown" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="15sp" android:background="#FFF3E0" android:padding="6dp" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/dashboard_distance" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="15sp" android:background="#E8F5E9" android:padding="6dp" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/dashboard_trailing_note" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@android:color/darker_gray" android:padding="6dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
