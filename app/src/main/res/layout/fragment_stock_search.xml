<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/analysis_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="其它股票分析"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <AutoCompleteTextView
                android:id="@+id/search_stock_edit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="输入股票代码或名称搜索..."
                android:maxLines="1"
                android:completionThreshold="1"
                android:inputType="textFilter"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="8dp" />

            <TextView
                android:id="@+id/selected_stock_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#E8F5E9"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/ai_analysis_btn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="AI分析此股"
                    android:textColor="@android:color/white"
                    android:backgroundTint="@color/red_primary"
                    android:visibility="gone"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/clear_chat_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="清除"
                    android:textSize="13sp"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#757575"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <ScrollView
        android:id="@+id/chat_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="4dp"
        android:background="#F5F5F5"
        android:visibility="gone"
        android:isScrollContainer="false">

        <LinearLayout
            android:id="@+id/chat_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <LinearLayout
        android:id="@+id/input_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/chat_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="输入你想咨询的问题..."
            android:inputType="text"
            android:maxLines="3"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/send_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="发送"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/red_primary" />
    </LinearLayout>

    <TextView
        android:id="@+id/empty_hint"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="搜索并选择一只股票，点击AI分析此股获取专业的选股建议"
        android:textColor="@android:color/darker_gray"
        android:textSize="14sp"
        android:padding="24dp" />

</LinearLayout>
