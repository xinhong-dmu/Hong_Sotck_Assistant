<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="API 设置"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DeepSeek API Key"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/settings_api_key"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="请输入 DeepSeek API Key"
                    android:inputType="textPassword"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/get_api_key_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="获取API Key"
                    android:textSize="12sp"
                    android:visibility="gone"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DeepSeek 模型"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/model_spinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@android:drawable/edit_text"
                android:padding="8dp"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/save_settings_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="保存设置"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/red_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/save_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#4CAF50"
                android:textSize="13sp"
                android:visibility="gone"
                android:layout_marginTop="8dp"
                android:gravity="center" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="使用说明"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autoLink="web"
                android:text="1. 前往 https://platform.deepseek.com 注册并获取 API Key\n\n2. 将 API Key 粘贴到上方输入框\n\n3. 选择使用的模型：\n   • DeepSeek V4 Pro — 旗舰模型，分析能力最强\n   • DeepSeek Flash — 快速响应，适合简单查询\n\n4. 点击保存设置，即可在AI分析中使用"
                android:textSize="13sp"
                android:textColor="#333333"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
